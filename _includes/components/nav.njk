            <div class="flex-shrink-0 flex items-center gap-3 cursor-pointer">
                <a href="/" class="flex items-center gap-3">
                    <div class="bg-brand-surface border border-brand-border/60 p-1.5 rounded-lg h-10 w-10 flex items-center justify-center" style="width: 40px; height: 40px; min-width: 40px; min-height: 40px;">
                        <picture>
                          <source srcset="/logo/logo.webp 1x" type="image/webp">
                          <img src="/logo/logo.png" width="40" height="40" alt="{{ site.name }} Logo" class="h-full w-full object-contain" style="width: 100%; height: 100%; max-width: 40px; max-height: 40px; object-fit: contain;">
                        </picture>
                    </div>
                    <span class="font-bold text-2xl text-brand-dark tracking-tight transition-colors duration-200 ease-in-out">GateRemote<span class="text-brand-accent">Source</span></span>
                </a>
            </div>

            <!-- Desktop Menu -->
