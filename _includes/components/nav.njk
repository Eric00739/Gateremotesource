                                <span class="text-brand-dark">Italiano</span>
                            </a>
                            <a href="#" onclick="changeLanguage('fr')" class="flex items-center gap-3 px-4 py-3 text-brand-dark hover:bg-brand-light transition">
                                <span class="text-xs font-semibold text-brand-dark">FR</span>
                                <span class="text-brand-dark">French</span>
                            </a>
                            <a href="#" onclick="changeLanguage('pt')" class="flex items-center gap-3 px-4 py-3 text-brand-dark hover:bg-brand-light transition">
                                <span class="text-xs font-semibold text-brand-dark">PT</span>
                                <span class="text-brand-dark">Portuguese</span>
                            </a>
