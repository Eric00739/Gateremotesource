                            <span id="currentLang" class="sr-only">English</span>
                            <i class="fa-solid fa-chevron-down text-xs"></i>
                        </button>
                        <div id="languageDropdown" class="absolute right-0 mt-2 w-48 bg-brand-surface border border-brand-border rounded-lg shadow-lg hidden z-50 backdrop-blur">
                            <a href="#" onclick="changeLanguage('en')" class="flex items-center gap-3 px-4 py-3 text-brand-dark hover:bg-brand-light transition">
                                <span class="text-xs font-semibold text-brand-dark">EN</span>
                                <span class="text-brand-dark">English</span>
                            </a>
                            <a href="#" onclick="changeLanguage('es')" class="flex items-center gap-3 px-4 py-3 text-brand-dark hover:bg-brand-light transition">
                                <span class="text-xs font-semibold text-brand-dark">ES</span>
                                <span class="text-brand-dark">Spanish</span>
                            </a>
                            <a href="#" onclick="changeLanguage('de')" class="flex items-center gap-3 px-4 py-3 text-brand-dark hover:bg-brand-light transition">
                                <span class="text-xs font-semibold text-brand-dark">DE</span>
                                <span class="text-brand-dark">Deutsch</span>
