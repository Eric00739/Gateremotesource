                <a href="/contact/" class="nav-link text-brand-dark hover:text-brand-accent transition-colors duration-200 ease-in-out font-semibold py-2 border-b-2 border-transparent hover:border-brand-accent" id="nav-contact" data-i18n="navigation.contact">Contact</a>

                <!-- Language Switcher -->
