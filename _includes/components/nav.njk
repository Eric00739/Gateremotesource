            <a href="/" class="block py-2 text-brand-dark hover:text-brand-accent font-semibold" data-i18n="navigation.home">Home</a>
            <a href="/catalog/" class="block py-2 text-brand-dark hover:text-brand-accent font-semibold" data-i18n="navigation.catalog">Catalog</a>
            <a href="/oem/" class="block py-2 text-brand-dark hover:text-brand-accent font-semibold" data-i18n="navigation.oem">OEM/ODM</a>
            <a href="/about/" class="block py-2 text-brand-dark hover:text-brand-accent font-semibold" data-i18n="navigation.about">About</a>
            <a href="/blog/" class="block py-2 text-brand-dark hover:text-brand-accent font-semibold" data-i18n="navigation.blog">Blog</a>
            <a href="/contact/" class="block py-2 text-brand-dark hover:text-brand-accent font-semibold" data-i18n="navigation.contact">Contact</a>
            <a href="/contact/" class="block mt-4 bg-brand-cta hover:bg-brand-ctaHover text-brand-surface px-6 py-3 rounded-lg font-bold text-center" data-i18n="navigation.dealer_login">Quote now</a>
        </div>
    </div>
