{# Main Navigation Component #}
<a href="#main-content" class="skip-link sr-only focus:not-sr-only focus:absolute focus:top-0 focus:left-0 focus:z-50 focus:bg-brand-accent focus:text-white focus:px-4 focus:py-2">Skip to main content</a>

<nav aria-label="Main navigation" class="sticky top-0 w-full z-50 nav-glass nav-enhanced transition-all duration-200 ease-in-out">
