<!-- Security Headers for GitHub Pages -->
<!-- 由于 GitHub Pages 不支持自定义 HTTP 头部，我们使用 meta 标签提供部分保护 -->

<!-- Content Security Policy (CSP) - 使用 meta 标签 -->
<meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://cdn.jsdelivr.net https://player.vimeo.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https://www.google-analytics.com; frame-src https://player.vimeo.com; media-src 'self'; form-action 'self'; base-uri 'self';">

<!-- X-Content-Type-Options -->
<meta http-equiv="X-Content-Type-Options" content="nosniff">

<!-- Referrer Policy -->
<meta name="referrer" content="strict-origin-when-cross-origin">

<!-- Permissions Policy -->
<meta http-equiv="Permissions-Policy" content="geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=(), ambient-light-sensor=(), bluetooth=(), midi=(), notifications=(), push=(), sync-xhr=(), encrypted-media=(), picture-in-picture=(), idle-detection=(), screen-wake-lock=()">

<!-- X-Frame-Options -->
<meta http-equiv="X-Frame-Options" content="DENY">

<!-- Cross-Origin Opener Policy -->
<meta http-equiv="Cross-Origin-Opener-Policy" content="same-origin">

<!-- Cross-Origin Embedder Policy -->
<meta http-equiv="Cross-Origin-Embedder-Policy" content="require-corp">
