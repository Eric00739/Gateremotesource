---
pagination:
  data: compatibility.brands
  size: 1
  alias: brand
  addAllPagesToCollections: true
permalink: "compatibility/{{ brand.slug }}/index.html"
---
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ brand.name }} Compatible Gate Remotes | GateRemoteSource</title>
  <meta name="description" content="Compatibility notes for {{ brand.name }} replacement gate and garage remotes: receiver family, frequency, protocol, and wholesale validation workflow.">
  <meta name="keywords" content="{{ brand.name }} compatible remote, {{ brand.name }} gate remote replacement, wholesale garage remote compatibility">
  <meta name="author" content="GateRemoteSource">
  <link rel="canonical" href="{{ site.url }}/compatibility/{{ brand.slug }}/">
  <meta property="og:type" content="article">
  <meta property="og:site_name" content="{{ site.name }}">
  <meta property="og:title" content="{{ brand.name }} Compatible Gate Remotes | GateRemoteSource">
  <meta property="og:description" content="{{ brand.note }}">
  <meta property="og:url" content="{{ site.url }}/compatibility/{{ brand.slug }}/">
  <meta property="og:image" content="{{ site.url }}/assets/factory/rd-lab.webp">
  <link rel="icon" type="image/x-icon" href="/logo/favicon.ico?v=1">
  <link rel="stylesheet" href="/assets/css/tailwind.css">
  <link rel="stylesheet" href="/assets/vendor/fontawesome/css/all.min.css">
  <link rel="stylesheet" href="/assets/css/fonts.css">
  <link rel="stylesheet" href="/styles/enhanced.css">
  {% include "components/redirect.njk" %}
</head>
<body class="bg-brand-light text-brand-dark">
  {% include "components/nav.njk" %}
  <main id="main-content">
    <section class="bg-brand-surface border-b border-brand-border">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
        <a href="/compatibility/" class="text-sm font-bold text-brand-accent hover:underline">Compatibility hub</a>
        <h1 class="mt-4 text-4xl md:text-5xl font-bold tracking-tight">{{ brand.name }} compatible gate remotes</h1>
        <p class="mt-6 max-w-3xl text-lg text-brand-muted leading-relaxed">{{ brand.ecosystem }}</p>
      </div>
    </section>

    <section class="py-16">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 space-y-8">
        <div class="bg-brand-surface border border-brand-border rounded-lg p-6">
          <h2 class="text-2xl font-bold">Compatibility checks</h2>
          <dl class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <dt class="text-sm font-bold uppercase tracking-wide text-brand-accent">Frequency</dt>
              <dd class="mt-2 text-brand-muted">{{ brand.frequency }}</dd>
            </div>
            <div>
              <dt class="text-sm font-bold uppercase tracking-wide text-brand-accent">Validation note</dt>
              <dd class="mt-2 text-brand-muted">{{ brand.note }}</dd>
            </div>
          </dl>
        </div>

        <div class="bg-brand-surface border border-brand-border rounded-lg p-6">
          <h2 class="text-2xl font-bold">Wholesale workflow</h2>
          <ol class="mt-4 space-y-3 text-brand-muted list-decimal list-inside">
            <li>Send receiver label photos, original remote front and back photos, and required quantity.</li>
            <li>Confirm frequency, coding type, channel count, and learn-button procedure.</li>
            <li>Test samples before bulk production when the receiver generation is unclear.</li>
          </ol>
        </div>

        <div class="flex flex-wrap gap-3">
          <a href="/contact/" class="bg-brand-cta hover:bg-brand-ctaHover text-white px-5 py-3 rounded-lg font-bold">Ask for matching support</a>
          <a href="/blog/nice-came-hormann-compatibility-guide/" class="border border-brand-border hover:border-brand-accent px-5 py-3 rounded-lg font-bold">Read compatibility guide</a>
        </div>
      </div>
    </section>
  </main>
  {% include "components/footer.njk" %}
</body>
</html>
